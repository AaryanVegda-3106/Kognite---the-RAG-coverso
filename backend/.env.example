# ─── Database ────────────────────────────────────────────────────────────────
# On Render: use the "Internal Database URL" from your PostgreSQL service
# Locally: leave unset to use SQLite fallback (sqlite:///./kognite.db)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Frontend URL (for CORS) ──────────────────────────────────────────────────
# Set to your deployed Render frontend URL (no trailing slash)
FRONTEND_URL=https://your-frontend.onrender.com

# ─── AI / ML APIs ────────────────────────────────────────────────────────────
HUGGINGFACE_API_KEY=hf_...
GEMINI_API_KEY=...
NVIDIA_API_KEY=nvapi-...

# ─── Qdrant Vector DB ─────────────────────────────────────────────────────────
# Use Qdrant Cloud URL for production (local path won't work on Render)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=...
